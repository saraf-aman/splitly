rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function isHouseholdAdmin(householdId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Reverse index of uid -> householdId, written by the user themself on
      // create/join so the client can find "which household am I in" right
      // after login without a collection-group query.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      // Household creation is a two-write bootstrap (household doc + creator's own
      // admin member doc). Anyone signed in can create a household naming themselves
      // as createdBy; the matching member-doc rule below is what actually lets that
      // creator grant themselves the admin role, and only for a household they created.
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isHouseholdAdmin(householdId);

      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdAdmin(householdId) ||
          (memberId == request.auth.uid &&
           request.resource.data.role == 'admin' &&
           get(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid) ||
          // Self-join via invite: anyone who knows the household ID can add
          // themselves as a guest, as long as the household actually exists.
          // Role changes beyond that require an admin (see update/delete below).
          (memberId == request.auth.uid &&
           request.resource.data.role == 'guest' &&
           exists(/databases/$(database)/documents/households/$(householdId)));
        allow update, delete: if isHouseholdAdmin(householdId);
      }
    }

    match /bills/{billId} {
      allow read, update, delete: if isHouseholdMember(resource.data.householdId);
      allow create: if isHouseholdMember(request.resource.data.householdId);

      match /items/{itemId} {
        allow read, write: if isHouseholdMember(
          get(/databases/$(database)/documents/bills/$(billId)).data.householdId
        );
      }

      match /sharedCharges/{chargeId} {
        allow read, write: if isHouseholdMember(
          get(/databases/$(database)/documents/bills/$(billId)).data.householdId
        );
      }
    }
  }
}
