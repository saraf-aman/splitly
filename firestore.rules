rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function isHouseholdAdmin(householdId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // The household's creator is a permanent "super-admin": only they can
    // demote/remove another admin or touch another admin's role. Regular
    // admins can promote guests to admin and remove guests, but cannot act
    // on other admins at all, and nobody (including the creator themself)
    // can demote or remove the creator's own member doc.
    function isHouseholdCreator(householdId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      // Reverse index of uid -> householdId, written by the user themself on
      // create/join so the client can find "which household am I in" right
      // after login without a collection-group query.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      // Household creation is a two-write bootstrap (household doc + creator's own
      // admin member doc). Anyone signed in can create a household naming themselves
      // as createdBy; the matching member-doc rule below is what actually lets that
      // creator grant themselves the admin role, and only for a household they created.
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isHouseholdAdmin(householdId);
      // Deleting the whole household (wiping all members/bills/data) is
      // creator-only — the most destructive action in the app.
      allow delete: if isHouseholdCreator(householdId);

      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdAdmin(householdId) ||
          (memberId == request.auth.uid &&
           request.resource.data.role == 'admin' &&
           get(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid) ||
          // Self-join via invite: anyone who knows the household ID can add
          // themselves as a guest, as long as the household actually exists.
          // Role changes beyond that require an admin (see update/delete below).
          (memberId == request.auth.uid &&
           request.resource.data.role == 'guest' &&
           exists(/databases/$(database)/documents/households/$(householdId)));
        // Any member can update their own fcmTokens field (device push tokens).
        // The creator's own member doc can never be touched for role changes by anyone.
        allow update: if
          (isHouseholdMember(householdId) &&
           memberId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens', 'email'])) ||
          (isHouseholdAdmin(householdId) &&
           memberId != get(/databases/$(database)/documents/households/$(householdId)).data.createdBy &&
           (
             isHouseholdCreator(householdId) ||
             (resource.data.role == 'guest' && request.resource.data.role == 'admin')
           ));
        allow delete: if
          // Any non-creator member can leave on their own, regardless of role.
          // Multi-household makes leaving a normal self-service action.
          (memberId == request.auth.uid &&
           request.auth.uid != get(/databases/$(database)/documents/households/$(householdId)).data.createdBy) ||
          // Admin-initiated removals (unchanged):
          // - Creator can delete their own doc as the final step of deleteHousehold.
          // - Creator can remove any other member.
          // - Admin can remove a guest.
          (isHouseholdAdmin(householdId) &&
            (
              (memberId == request.auth.uid && isHouseholdCreator(householdId)) ||
              (
                memberId != get(/databases/$(database)/documents/households/$(householdId)).data.createdBy &&
                (
                  isHouseholdCreator(householdId) ||
                  resource.data.role == 'guest'
                )
              )
            )
          );
      }
    }

    match /bills/{billId} {
      allow read, update, delete: if isHouseholdMember(resource.data.householdId);
      allow create: if isHouseholdMember(request.resource.data.householdId);

      match /items/{itemId} {
        allow read, create, delete: if isHouseholdMember(
          get(/databases/$(database)/documents/bills/$(billId)).data.householdId
        );
        // update: household members may only change their own key inside `selections`.
        // The bill uploader (uploadedBy) may change any member's key.
        allow update: if isHouseholdMember(
            get(/databases/$(database)/documents/bills/$(billId)).data.householdId
          ) && (
            get(/databases/$(database)/documents/bills/$(billId)).data.uploadedBy == request.auth.uid
            ||
            request.resource.data.selections.diff(resource.data.selections)
              .affectedKeys().hasOnly([request.auth.uid])
          );
      }

      match /sharedCharges/{chargeId} {
        allow read, write: if isHouseholdMember(
          get(/databases/$(database)/documents/bills/$(billId)).data.householdId
        );
      }
    }
  }
}
